option_settings:
  aws:ec2:vpc:
    # Place the environment in the same VPC as the RDS database so the
    # container can reach PostgreSQL over the private network.
    VPCId: vpc-0aca7fbea9e69032a
    # Public subnets give the instance a route to the internet (for EB
    # bootstrapping) while still routing internally to the private RDS subnets.
    Subnets: subnet-06d11b60749864970,subnet-09fe67ec555deae74
    AssociatePublicIpAddress: true
  aws:autoscaling:launchconfiguration:
    # Dedicated SG that is whitelisted on the RDS security group for port 5432.
    SecurityGroups: sg-04842ab1ae4294f1a